<Page x:Class="NtfyDesktop.Features.Connections.ConnectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent"
      ScrollViewer.CanContentScroll="False"
      Title="Connections">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <DockPanel LastChildFill="True" Background="Transparent">

        <Grid DockPanel.Dock="Top" Margin="32,20,32,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <ui:TextBlock FontTypography="TitleLarge" Text="Connections" />
                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              FontTypography="Body"
                              Text="Live connection status for each subscribed topic." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Secondary"
                           Content="Disconnect all"
                           Icon="{ui:SymbolIcon PlugDisconnected24}"
                           Margin="0,0,8,0"
                           Command="{Binding DisconnectAllCommand}" />
                <ui:Button Appearance="Secondary"
                           Content="Reconnect all"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Command="{Binding ReconnectAllCommand}" />
            </StackPanel>
        </Grid>

        <Grid Margin="32,0,0,0">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="380"
                        Margin="0,0,32,0"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <ui:SymbolIcon Symbol="PlugDisconnected24"
                               FontSize="48"
                               Opacity="0.30"
                               HorizontalAlignment="Center" />
                <ui:TextBlock Margin="0,12,0,4"
                              FontTypography="Subtitle"
                              HorizontalAlignment="Center"
                              Text="No topics configured" />
                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              FontTypography="Body"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              TextWrapping="Wrap"
                              Text="Use the ‘Add topic’ entry in the sidebar to start receiving notifications." />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,14,0,14"
                                    Margin="0,0,32,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0"
                                             Width="10" Height="10"
                                             Margin="0,6,12,0"
                                             VerticalAlignment="Top"
                                             Fill="{Binding StatusBrush}" />
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:TextBlock FontTypography="BodyStrong"
                                                          Text="{Binding DisplayName}"
                                                          VerticalAlignment="Center" />
                                            <ui:TextBlock Margin="10,0,0,0"
                                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                          Text="{Binding StatusText}"
                                                          VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ui:TextBlock Margin="0,2,0,0"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      FontTypography="Caption"
                                                      Text="{Binding ServerName}"
                                                      Visibility="{Binding ShowServer, Converter={StaticResource BoolToVis}}" />
                                        <ui:TextBlock Margin="0,4,0,0"
                                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                      FontTypography="Caption"
                                                      TextWrapping="Wrap"
                                                      Text="{Binding LastError}"
                                                      Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="2"
                                               Appearance="Secondary"
                                               Icon="{ui:SymbolIcon ArrowSync24}"
                                               Content="Reconnect"
                                               VerticalAlignment="Center"
                                               Command="{Binding DataContext.ReconnectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding TopicId}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Page>
