<Page x:Class="NtfyDesktop.Features.Settings.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:domain="clr-namespace:NtfyDesktop.Domain"
      xmlns:settings="clr-namespace:NtfyDesktop.Features.Settings"
      xmlns:conv="clr-namespace:NtfyDesktop.Features.Shell.Converters"
      ScrollViewer.CanContentScroll="False"
      Title="Settings">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <ObjectDataProvider x:Key="Priorities"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="domain:Priority" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="RailDisplays"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="settings:RailServerDisplay" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,14,0,14" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="ui:TextBlock">
            <Setter Property="FontTypography" Value="BodyStrong" />
            <Setter Property="Margin" Value="0,28,0,4" />
        </Style>

        <Style x:Key="RowTitle" TargetType="ui:TextBlock">
            <Setter Property="FontTypography" Value="Body" />
        </Style>

        <Style x:Key="RowDescription" TargetType="ui:TextBlock">
            <Setter Property="FontTypography" Value="Caption" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

    </Page.Resources>

    <DockPanel LastChildFill="True" Margin="0,0,0,0" Background="Transparent">

        <Grid DockPanel.Dock="Top" Margin="32,20,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <ui:TextBlock FontTypography="TitleLarge" Text="Settings" />
                <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              FontTypography="Body"
                              Text="Server, defaults, and topic subscriptions." />
            </StackPanel>
            <!-- Unsaved-changes pill: visible in the page header so users see it
                 without scrolling all the way down to the Save button. -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    CornerRadius="4"
                    Padding="10,4,10,4"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                <ui:TextBlock FontTypography="Caption"
                              VerticalAlignment="Center"
                              Text="• Unsaved changes" />
            </Border>
        </Grid>

        <ScrollViewer x:Name="MainScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent"
                      Padding="32,0,32,0">
            
            <StackPanel Background="Transparent">

                <!-- ======================= SERVERS ======================= -->
                <ui:TextBlock Style="{StaticResource SectionTitle}" Text="Servers" Margin="0,12,0,4" />
                <ui:TextBlock Style="{StaticResource RowDescription}"
                              Margin="0,0,0,4"
                              Text="ntfy servers you subscribe to. Each topic belongs to one server; new topics use the default." />

                <ItemsControl ItemsSource="{Binding Servers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:TextBlock Style="{StaticResource RowTitle}"
                                                          Text="{Binding Name}"
                                                          VerticalAlignment="Center" />
                                            <Border Margin="8,0,0,0" Padding="6,1"
                                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="3"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                                <ui:TextBlock FontTypography="Caption"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                              Text="Default" />
                                            </Border>
                                        </StackPanel>
                                        <ui:TextBlock Style="{StaticResource RowDescription}" Text="{Binding Url}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button Appearance="Secondary"
                                                   Content="Set default"
                                                   Margin="0,0,8,0"
                                                   Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolToVis}}"
                                                   Command="{Binding DataContext.SetDefaultServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding Server}" />
                                        <ui:Button Appearance="Secondary"
                                                   Content="Edit"
                                                   Margin="0,0,8,0"
                                                   Tag="{Binding Server}"
                                                   Click="OnEditServerClicked" />
                                        <ui:Button Appearance="Secondary"
                                                   Content="Remove"
                                                   Tag="{Binding Server}"
                                                   Click="OnRemoveServerClicked" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:Button Appearance="Secondary"
                           Content="Add server"
                           Margin="0,12,0,0"
                           Icon="{ui:SymbolIcon Add24}"
                           Click="OnAddServerClicked" />

                <!-- ======================= DEFAULTS ======================= -->
                <ui:TextBlock Style="{StaticResource SectionTitle}" Text="Defaults" />

                <Border Style="{StaticResource SettingRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="Minimum priority (global)" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="Drop messages below this priority. Per-topic overrides take precedence." />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="160"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Source={StaticResource Priorities}}"
                                  SelectedItem="{Binding GlobalMinPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="History retention" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="Older messages are pruned by the background sweep." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:NumberBox Width="120"
                                          Minimum="1"
                                          Maximum="365"
                                          ClearButtonEnabled="False"
                                          Value="{Binding HistoryRetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Text="days" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================= SYSTEM ======================= -->
                <ui:TextBlock Style="{StaticResource SectionTitle}" Text="System" />

                <Border Style="{StaticResource SettingRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="Start with Windows" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="Launch this app at sign-in (minimised to tray)." />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1"
                                         VerticalAlignment="Center"
                                         IsChecked="{Binding StartWithWindows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <!-- ======================= APPEARANCE ======================= -->
                <ui:TextBlock Style="{StaticResource SectionTitle}" Text="Appearance" />

                <Border Style="{StaticResource SettingRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="Server labels in sidebar" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="How topics show which server they belong to. Only visible with more than one server." />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="160"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Source={StaticResource RailDisplays}}"
                                  SelectedItem="{Binding RailServerDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <!-- ======================= ACTIVE HOURS ======================= -->
                <ui:TextBlock Style="{StaticResource SectionTitle}" Text="Active hours" />

                <Border Style="{StaticResource SettingRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="Only notify during active hours" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="Outside this window messages are still recorded but no toast is shown." />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1"
                                         VerticalAlignment="Center"
                                         IsChecked="{Binding ActiveHoursEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingRow}"
                        Visibility="{Binding ActiveHoursEnabled, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <ui:TextBlock Style="{StaticResource RowTitle}" Text="Window" />
                            <ui:TextBlock Style="{StaticResource RowDescription}" Text="Wraps past midnight when end &lt; start (e.g. 22:00 → 06:00)." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:TextBox Width="80"
                                        Text="{Binding ActiveHoursStartText, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:TextBlock Margin="8,0,8,0"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          Text="to" />
                            <ui:TextBox Width="80"
                                        Text="{Binding ActiveHoursEndText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================= ACTIONS ======================= -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,28,0,28">
                    <ui:Button Appearance="Secondary"
                               Content="Discard"
                               Width="120"
                               Margin="0,0,8,0"
                               Click="OnDiscardClicked" />
                    <ui:Button Appearance="Primary"
                               Content="Save"
                               Width="120"
                               IsEnabled="{Binding CanSave}"
                               Click="OnSaveClicked" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
