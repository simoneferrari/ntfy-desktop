<ui:FluentWindow x:Class="NtfyDesktop.Features.Settings.Dialogs.ServerEditorDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Server"
                 Width="460"
                 SizeToContent="Height"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />

        <StackPanel Grid.Row="1" Margin="24,8,24,24">
            <ui:TextBlock FontTypography="Subtitle" Text="Name" />
            <ui:TextBox Margin="0,4,0,16"
                        PlaceholderText="e.g. Home, ntfy.sh"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

            <ui:TextBlock FontTypography="Subtitle" Text="Server URL" />
            <ui:TextBox Margin="0,4,0,2"
                        PlaceholderText="https://ntfy.sh"
                        Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
            <ui:TextBlock Margin="0,0,0,16"
                          TextWrapping="Wrap"
                          FontTypography="Caption"
                          Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                          Text="{Binding UrlError}"
                          Visibility="{Binding HasUrlError, Converter={StaticResource BoolToVis}}" />

            <ui:TextBlock FontTypography="Subtitle" Text="Access token" />
            <ui:TextBlock Margin="0,2,0,4"
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Text="Optional bearer token for authenticated topics." />
            <PasswordBox x:Name="TokenBox" PasswordChanged="OnTokenChanged" />
            <ui:TextBlock Margin="0,4,0,0"
                          TextWrapping="Wrap"
                          FontTypography="Caption"
                          Foreground="{DynamicResource SystemFillColorCautionBrush}"
                          Text="⚠ This server uses plain HTTP. The token will not be sent — switch to HTTPS for authentication."
                          Visibility="{Binding HasInsecureTokenWarning, Converter={StaticResource BoolToVis}}" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <ui:Button Appearance="Secondary"
                           Content="Cancel"
                           Width="100"
                           Margin="0,0,8,0"
                           Click="OnCancelClicked" />
                <ui:Button Appearance="Primary"
                           Content="Save"
                           Width="100"
                           Click="OnSaveClicked" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
