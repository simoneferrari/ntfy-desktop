<ui:FluentWindow x:Class="NtfyDesktop.Features.Rules.Editor.SampleMessagePickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Pick a sample message"
                 Width="560"
                 Height="520"
                 MinWidth="420"
                 MinHeight="360"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 ResizeMode="CanResize"
                 ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Pick a sample message" />

        <ui:TextBlock Grid.Row="1" Margin="16,8,16,4"
                      FontTypography="Caption"
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                      Text="Pick a message that should match. Its text fills the field (as 'Contains'); tweak afterwards." />

        <Border Grid.Row="2" Margin="16,0,16,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="MessageList"
                     MouseDoubleClick="OnMessageDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <ui:TextBlock FontTypography="BodyStrong" TextWrapping="Wrap" Text="{Binding DisplayTitle}" />
                            <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="{Binding Body}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,12,16,16">
            <ui:Button Content="Cancel" Margin="0,0,8,0" Click="OnCancel" />
            <ui:Button Content="Use this message" Appearance="Primary" Click="OnUse" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
