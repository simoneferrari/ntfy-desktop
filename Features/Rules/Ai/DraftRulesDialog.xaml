<ui:FluentWindow x:Class="NtfyDesktop.Features.Rules.Ai.DraftRulesDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Draft rules with AI"
                 Width="640"
                 Height="700"
                 MinWidth="520"
                 MinHeight="520"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 ResizeMode="CanResize"
                 ShowInTaskbar="False">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Draft rules with AI" />

        <!-- ============================ STEP 1: INPUTS ============================ -->
        <Grid Grid.Row="1" Margin="24,8,24,0"
              Visibility="{Binding IsInputStep, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Caption" Text="Topic" />
                        <ComboBox Width="180" Margin="0,2,0,0"
                                  ItemsSource="{Binding Topics}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedTopic, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="16,0,0,0">
                        <ui:TextBlock FontTypography="Caption" Text="Model" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <ComboBox Width="190" IsEditable="True"
                                      ItemsSource="{Binding Models}"
                                      Text="{Binding SelectedModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Appearance="Secondary" Margin="6,0,0,0" Content="Refresh"
                                       Command="{Binding RefreshModelsCommand}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <ui:TextBlock FontTypography="Subtitle" Text="Sample messages" />
                <ui:TextBlock Margin="0,2,0,0"
                              FontTypography="Caption"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextWrapping="Wrap"
                              Text="Pick representative messages. The AI uses these (and your intent) to draft rules." />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8" VerticalAlignment="Center">
                <ui:TextBlock VerticalAlignment="Center" Text="Show" />
                <ComboBox Width="70" Margin="8,0,0,0"
                          ItemsSource="{Binding LoadCounts}"
                          SelectedItem="{Binding LoadCount, Mode=TwoWay}" />
                <ui:Button Appearance="Secondary" Margin="12,0,0,0" Content="Select all"
                           Command="{Binding SelectAllCommand}" />
                <ui:Button Appearance="Secondary" Margin="8,0,0,0" Content="Deselect all"
                           Command="{Binding DeselectAllCommand}" />
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Samples}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,2"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Content="{Binding Display}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <ui:TextBlock FontTypography="Subtitle" Text="Or paste messages (one per line)" />
                <ui:TextBox Margin="0,4,0,0"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            MinHeight="48"
                            MaxHeight="96"
                            VerticalScrollBarVisibility="Auto"
                            Text="{Binding PasteText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,12,0,0">
                <ui:TextBlock FontTypography="Subtitle" Text="Intent (optional)" />
                <ui:TextBox Margin="0,4,0,0"
                            PlaceholderText="e.g. backup successes are noise unless they stop; pair problem/resolved by event id"
                            Text="{Binding Intent, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <!-- ============================ STEP 2: REVIEW ============================ -->
        <Grid Grid.Row="1" Margin="24,8,24,0"
              Visibility="{Binding IsReviewStep, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" FontTypography="Subtitle" Text="Proposed rules" />
            <Border Grid.Row="1" Margin="0,4,0,0" MaxHeight="170"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SummaryLines}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:TextBlock Margin="0,2" TextWrapping="Wrap" Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <ui:TextBlock Grid.Row="2" Margin="0,12,0,4" FontTypography="Subtitle" Text="Pack JSON (editable)" />
            <ui:TextBox Grid.Row="3"
                        AcceptsReturn="True"
                        TextWrapping="NoWrap"
                        FontFamily="Cascadia Mono, Consolas, monospace"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        Text="{Binding DraftJson, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- error (both steps) -->
        <ui:TextBlock Grid.Row="2" Margin="24,8,24,0"
                      TextWrapping="Wrap"
                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                      Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                      Text="{Binding ErrorText}" />

        <!-- footer -->
        <Grid Grid.Row="3" Margin="24,12,24,24">
            <!-- Step 1 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Visibility="{Binding IsInputStep, Converter={StaticResource BoolToVis}}">
                <ui:ProgressRing Width="22" Height="22" Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <ui:Button Content="Cancel" Margin="0,0,8,0" Click="OnCancelClicked" />
                <ui:Button Appearance="Primary"
                           Content="Generate"
                           Icon="{ui:SymbolIcon Sparkle24}"
                           IsEnabled="{Binding CanGenerate}"
                           Command="{Binding GenerateCommand}" />
            </StackPanel>
            <!-- Step 2 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Visibility="{Binding IsReviewStep, Converter={StaticResource BoolToVis}}">
                <ui:Button Content="← Back" Margin="0,0,8,0" Command="{Binding BackCommand}" />
                <ui:Button Content="Cancel" Margin="0,0,8,0" Click="OnCancelClicked" />
                <ui:Button Appearance="Primary" Content="Save pack" Click="OnSaveClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
